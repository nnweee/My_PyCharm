import pandas as pd

tablitsa = "GroupPerformanceAndAttendance-1.xlsx"
df = pd.read_excel(tablitsa, sheet_name="Отчёт", skiprows=5)

#переименование столбцов
column = [
    "Ф.И. Студента",
    "Компьютерные сети",
    "Основы алгоритмизации и программирования",
    "Разработка программых модулей",
    "Системное программирование",
    "Пропущено часов занятий: Всего",
    "По уважительной причине",
    "По неуважительной причине"
]
#создание списка предметов
predmet = [
    "Компьютерные сети",
    "Основы алгоритмизации и программирования",
    "Разработка программых модулей",
    "Системное программирование"
]
#для цикла


#топ по каждому предмету
for subject in predmet:
    print(f"\n{subject}")
    top_students = df[["Ф.И. Студента", subject]].sort_values(by=subject, ascending=False)
    print(top_students.to_string(index=False))

#subject  переменная по очереди значения из списка predmet
#f"{subject}" подставляет значение переменной subject
#.sort_values(by=subject, ascending=False) сортирует по оценкам:
#by=subject сортируем по столбцу с оценками
#ascending=False по убыванию от 5 к 2
#.to_string() превращает таблицу в текст
#index=False убирает номера строк (типо: 0, 1, 2 и тд.)

#функция извлечения часов из строки
def extract_hours(hour_str):
    if pd.isna(hour_str):
        return 0
    return int(str(hour_str).split(" ч")[0])

#hour_str параметр (что передадим в функцию)
#pd.isna(hour_str) проверяет пустое ли значение
#return 0 если пустое возвращаем 0 (часов)
#.split(" ч") разбивает строку по "ч" получается что типо ["18", "/ 7,1 %"]
#[0] — берёт первый элемент "18"

#расчёт условных двоек
df["Часов пропущено"] = df["Пропущено часов занятий: Всего"].apply(extract_hours)
df["Условных двоек за пропуски"] = df["Часов пропущено"] // 2
#.apply(extract_hours) применяем функцию extract_hours к каждой строке
#//целочисленное деление 

#вывод таблицы с двойками
print("таблица с двойками за пропуски (2 часа = 1 пропуск = 1 двойка)")

result_df = df[["Ф.И. Студента", "Часов пропущено", "Условных двоек за пропуски"]]
print(result_df.to_string(index=False))

#итоговая сумма двоек по группе
total_dvoek = result_df["Условных двоек за пропуски"].sum()
print(f"\nВсего условных двоек по группе: {total_dvoek}")
