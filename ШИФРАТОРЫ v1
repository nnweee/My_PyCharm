import numpy as np

# Массив с русским алфавитом (ъ заменен на ь)
alfavit = np.array(['а', 'б', 'в', 'г', 'д', 'е', 'ё', 'ж', 'з', 'и', 'й', 'к', 'л', 'м',
                    'н', 'о', 'п', 'р', 'с', 'т', 'у', 'ф', 'х', 'ц', 'ч', 'ш', 'щ', 'ь', 'ы', 'э', 'ю', 'я'])

#.lower() - преобразует все буквы в нижний регистр (чтобы 'А' и 'а' обрабатывались одинаково)
# .replace('ъ', 'ь') - заменяет твердый знак на мягкий (согласно условию задачи)
# .replace(' ', '') - удаляет все пробелы из предложения (игнорирует их)

# кодируем предложение
sentence = input("Введите предложение: ").lower().replace('ъ', 'ь').replace(' ', '')

#Это list comprehension (генератор списка), который проходит по каждому символу в предложении
# np.where(alfavit == char) - ищет в массиве alfavit все позиции, где элемент равен char
# Возвращает кортеж из двух массивов: (индексы строк, индексы столбцов)
# Так как у нас одномерный массив, берем [0] - первый массив с индексами
# [0][0] - берем первый (и единственный) найденный индекс

# format(число, '05b') - преобразует число в двоичную систему счисления
# '05b' означает:
#   'b' - binary (двоичная система)
#   '0' - заполнять нулями слева
#   '5' - ширина поля 5 символов
# Например: format(0, '05b') -> '00000', format(1, '05b') -> '00001'

# В итоге codes - это список строк, каждая строка - 5-битный двоичный код буквы

# Генерация кодов с помощью NumPy
codes = [format(np.where(alfavit == char)[0][0], '05b') for char in sentence if char in alfavit]

print("\nРезультат:")
# ' '.join(codes) - объединяет все коды в одну строку, разделяя пробелами
print(' '.join(codes))
