import numpy as np

studentu = ["Афоркин","Семаева","Мешалкин","Никулин","Шипилевский","Николаев", # список студентов
        "Данилов","Мажукова","Малякова","Андреева","Михайлов","Исправников",
        "Куксенков","Денисов","Паштынов","Мартынов","Антонов","Кучкасков",
        "Эрипова","Тихонов","Александрова","Яковлев","Иванова","Андреев"]

rangom = np.array(np.random.permutation(studentu)) # np.random.permutation() - берет список studentu и перемешивает его случайным образом, исходный список остаеться прежним
# np.array() - преобразует перемешанный список в специальный массив numpy ()
resultaty = rangom.reshape(12, 2) # reshape () - изменяет форму массива, матрица 12 строк и 2 столбца

for i, pair in enumerate(resultaty, 1): # цикл проходит по каждой паре студентов. resultaty - таблица.
    
    # enumerate(result, 1) - нумерует каждую строку начиная с 1, без ",1" нумерация началась бы с 0
    # i получает номер компьютера
    # pair получает список из двух фамилий ("Шипилевский","Антонов")

    print(f"Компьютер {i}: {pair[0]} и {pair[1]}") 
