#клиент
import socket


def main():
    client_socket = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    client_socket.connect(("localhost", 6767))
    print("Подключено к серверу")

    vvod = input("Введите числа через пробел: ")

    #отправка данных на сервер
    client_socket.send(vvod.encode())

    #получение ответа от сервера
    otvet = client_socket.recv(1024).decode()

    print(f"Количество чётных чисел: {otvet}")

    #закрытие соединения
    client_socket.close()


if __name__ == "__main__":
    main()


