import pandas as pd
import numpy as np


df = pd.read_excel('1s.xlsx') #функция которая читает Excel файл и превращает его в DataFrame таблицу

subjects = ['Предмет1', 'Предмет2', 'Предмет3', 'Предмет4', 'Пердемет5']

#добавляем столбец со средним баллом (каждого студента)

df['avg'] = df[subjects].mean(axis=1)

#.mean(axis=1) — вычисляем среднее значение по строкам (axis=1 означает горизонтально)
#df[subjects] — выбираем из таблицы только столбцы с оценками.

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 1)cредний балл группы
print(f"1) средний балл группы = {df['avg'].mean():.2f}")

#df['avg'].mean() — берем столбец со средними баллами студентов и вычисляем его среднее.
#:.2f выводим число с двумя знаками после запятой (форматирование)
#f" " позволяет вставлять переменные прямо в текст (f строка)

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 2)cтуденты без троек
no_threes = df[(df[subjects] >= 4).all(axis=1)]
print(f"\n2) студенты не ищеющие троек, всего {len(no_threes)} человека:")
print(no_threes['name'].to_list())

#df[subjects] >= 4 проверяем каждую оценку, если оценка >= 4 то true, если 3 или меньше то false
#.all(axis=1) проверяем по каждой строке: все ли значения true (eсли у студента >= 4 то выводит true)
#no_threes['name'].to_list() берем столбец с именами и превращаем его в список Пайтон для более удобного вывода

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 3)cтуденты без стипендии
no_scholarship = df[df['stepen'] == 0]
print(f"\n3) студенты без стипендии, всего ({len(no_scholarship)} человек")
print(no_scholarship['name'].to_list())

#df['stepen'] == 0 проверяем у кого в столбце (stepen) стоит 0
#df[...] — оставляем студентов, у которых стипендия 0

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 4)cтуденты из Шумерли
shumerlya = df[df['Город проживания'] == 'Шумерля']
print(f"\n4) студенты из Шумерли, их {len(shumerlya)} ")
print(shumerlya[['name'] + subjects].to_string(index=False))

#df['Город проживания'] == 'Шумерля'  фильтрация по городу
#shumerlya[['name'] + subjects] выбираем столбцы имя и все предметы | ['name'] + subjects объединяет два списка в один.
#.to_string(index=False) выводим таблицу в виде текста, без индексов строк (потому что так чище и красивее])

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 5)cредний балл по каждому предмету
print(f"\n5) средний балл по каждому предемту:")
for i in subjects:
    print(f"   {i}: {df[i].mean():.2f}")

#df[sub].mean() вычесляет среднее арифметическое оценок по всем предметам в целом

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 6)cтуденты 18 лет
age_18 = df[df['aga'] == 18]
print(f"\n6) студенты,которым есть 18 лет - {len(age_18)} человека")
print(age_18['name'].to_list())

# df['aga'] == 18 некий фильтр по возрасту, возраст храниться в age

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

########## доп.задания (от себя) ##########

# 7)отличники (все оценки 5)
excellent = df[(df[subjects] == 5).all(axis=1)]
print(f"\n7) отличники ({len(excellent)} чел.):")
print(excellent['name'].to_list() if len(excellent) > 0 else "   Отличников нету)))")

#df[subjects] == 5  проверяем каждую оценку (=5)
#.all(axis=1) проверка, все ли оценки судента = 5

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 8)топ 3 студента по успеваемости
top3 = df.nlargest(3, 'avg')[['name', 'avg']]
print(f"\n8) топ-3 студента (среднее avg):")
print(top3.to_string(index=False))

#.nlargest(3, 'avg')  берем 3 строки, с наибольшими значениями в столбце avg| в данном случае считается средний балл
#[['name', 'avg']] выбираем только два столбца - имя и средний балл

#---------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 9)распределение по городам
print(f"\n9) распределение студентов по городам:")
print(df['Город проживания'].value_counts().to_string())

#.value_counts() считает, сколько раз встречается КАЖДОЕ уникальное значение в столбце. Автоматичая сортировка от большего к меньшему
#.to_string() просто преоброзование результата в строку (для красивого вывода)


#.to_string(index=False) скрывает нумерацию строк.(DataFrame)

#--------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------------

# 10)студенты у которых ровно три оценки 4
three_fours = df[(df[subjects] == 4).sum(axis=1) == 3]
print(f"\n10) студенты с ровно тремя четверками ({len(three_fours)} челеловека):")
print(three_fours[['name'] + subjects].to_string(index=False))

